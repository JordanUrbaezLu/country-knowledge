{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "index.ts",
    "db.ts",
    "auth.ts",
    "api.ts",
    "mpStats.ts",
    "insights.ts",
    "../src/multiplayer/roomGame.ts",
    "../src/multiplayer/protocol.ts"
  ]
}
