# ─────────────────────────────────────────────────────────────────────────────
# Environment TEMPLATE (committed). Copy it to a gitignored file and fill in REAL
# values — never put real values in this file:
#
#   cp .env.example .env.local      # preferred (Vite convention; *.local is gitignored)
#   # .env works too — both are gitignored and read by the server. .env.local wins.
#
# In PRODUCTION the host (Render dashboard) injects these directly; no file is used.
# Only VITE_-prefixed vars reach the browser bundle — they are PUBLIC. Never give a
# secret a VITE_ name.
# ─────────────────────────────────────────────────────────────────────────────

# --- Server (Node) — secrets, never exposed to the client ---

# Postgres connection string for accounts/stats (read in server/db.ts). The server
# runs fine without it (accounts disabled, guests still play), but throws if an
# account feature is used while unset. Example:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST/db?sslmode=require
DATABASE_URL=

# Secret used to sign session cookies (read in server/auth.ts). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Port the game server listens on (default 1999).
PORT=

# Anthropic API key — LOCAL ONLY, used by `npm run insights` (scripts/insights.ts)
# to generate the personalized player messages. The server never reads it; NEVER
# set it in production. Get one at console.anthropic.com → API keys.
ANTHROPIC_API_KEY=

# --- Client (Vite) — PUBLIC, baked into the browser bundle at build time ---

# Usually leave EMPTY. The server serves the app + WebSocket same-origin, and in
# dev `npm run dev` has Vite proxy /ws to the server — so the client connects
# automatically with no config. Set this ONLY if the frontend is hosted separately
# from the game server. Examples:
#   VITE_WS_HOST=127.0.0.1:1999
#   VITE_WS_HOST=your-app.onrender.com
VITE_WS_HOST=
