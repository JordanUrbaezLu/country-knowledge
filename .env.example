# Where the browser finds the PartyKit multiplayer server.
# Dev: leave unset — the client defaults to 127.0.0.1:1999 (run `npm run dev:mp`).
# Prod (Vercel): set this to your deployed PartyKit host from `npm run party:deploy`,
# e.g. country-knowledge.<your-partykit-username>.partykit.dev
VITE_PARTYKIT_HOST=
