{
  "name": "country-knowledge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mp": "concurrently -k -n web,ws -c cyan,magenta \"VITE_WS_HOST=127.0.0.1:1999 vite\" \"tsx watch server/index.ts\"",
    "play": "npm run build && npm start",
    "share": "npm run build && concurrently -k -n server,tunnel -c green,cyan \"npm start\" \"npx -y untun@latest tunnel http://localhost:1999\"",
    "server": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "build": "tsc --noEmit && vite build",
    "typecheck:server": "tsc -p server/tsconfig.json",
    "check": "npm run build && npm run typecheck:server && npm run test",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:states": "node scripts/build-states.mjs",
    "build:flags": "node scripts/build-flags.mjs"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-globe.gl": "^2.38.0",
    "sirv": "^3.0.2",
    "three": "^0.184.0",
    "tsx": "^4.22.4",
    "world-countries": "^5.1.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "partysocket": "^1.2.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
